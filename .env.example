# Configurações do Supabase para o Vambora! Penedo
# Renomeie este arquivo para .env.local e adicione as suas chaves reais.
# IMPORTANTE: Nunca commite o arquivo .env.local no Git!

# URL de API do projeto do Supabase (Ex: https://abcedfghij.supabase.co)
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co

# Chave pública anônima do Supabase (Anon Key / Public Key)
VITE_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI
